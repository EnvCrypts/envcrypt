# EnvCrypt example configuration
#
# Quick start:
#   1. Copy this file to .env
#   2. Keep the default SQLite settings for the easiest local setup
#   3. Run migrations with: goose up
#   4. Start the server

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
ADDR=:8080
ENV=development

# -----------------------------------------------------------------------------
# Database: local SQLite default
#
# This is the easiest setup for local development. No external database service
# is required.
# -----------------------------------------------------------------------------
DATABASE_DRIVER=sqlite
DATABASE_URL=file:./envcrypt.db?_time_format=sqlite&_pragma=foreign_keys(1)

# Goose uses its own environment variable names when run directly.
GOOSE_DRIVER=sqlite3
GOOSE_DBSTRING=file:./envcrypt.db?_time_format=sqlite&_pragma=foreign_keys(1)
GOOSE_MIGRATION_DIR=./internal/db/sqlite_migrations

# -----------------------------------------------------------------------------
# Docker Compose defaults
#
# Used by docker-compose.sqlite.yaml and docker-compose.postgres.yaml.
# You usually do not need to change these for a first run.
# -----------------------------------------------------------------------------
SQLITE_DATABASE_URL=file:/app/data/envcrypt.db?_time_format=sqlite&_pragma=foreign_keys(1)
DB_USER=envcrypt
DB_PASSWORD=envcrypt
# POSTGRES_DATABASE_URL=postgres://envcrypt:envcrypt@postgres:5432/envcrypt?sslmode=disable

# -----------------------------------------------------------------------------
# Database: local PostgreSQL alternative
#
# Uncomment this block if you prefer running against PostgreSQL locally.
# -----------------------------------------------------------------------------
# DATABASE_DRIVER=postgres
# DATABASE_URL=postgres://envcrypt:envcrypt@localhost:5432/envcrypt?sslmode=disable
# GOOSE_DRIVER=postgres
# GOOSE_DBSTRING=postgres://envcrypt:envcrypt@localhost:5432/envcrypt?sslmode=disable
# GOOSE_MIGRATION_DIR=./internal/db/migrations
