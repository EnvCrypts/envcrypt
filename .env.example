# App
ADDR=:8080
ENV=development

# SQLite docker compose default:
# docker compose up --build
DATABASE_DRIVER=sqlite
SQLITE_DATABASE_URL=file:/app/data/envcrypt.db?_time_format=sqlite&_pragma=foreign_keys(1)

# PostgreSQL docker compose:
# docker compose -f docker-compose.postgres.yaml up --build
# DATABASE_DRIVER=postgres
DB_USER=envcrypt
DB_PASSWORD=envcrypt
# POSTGRES_DATABASE_URL=postgres://envcrypt:envcrypt@postgres:5432/envcrypt?sslmode=disable

# Local PostgreSQL outside docker:
# DATABASE_DRIVER=postgres
# DATABASE_URL=postgres://envcrypt:envcrypt@localhost:5432/envcrypt?sslmode=disable

# Local SQLite outside docker:
# DATABASE_DRIVER=sqlite
# DATABASE_URL=file:./envcrypt.db?_time_format=sqlite&_pragma=foreign_keys(1)
